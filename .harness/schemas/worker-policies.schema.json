{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/worker-policies.schema.json",
  "title": "FrontierScan Harness Worker Policies",
  "type": "object",
  "required": ["schemaVersion", "roles"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "category", "readPathPrefixes", "writePathPrefixes", "capabilities"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "category": { "enum": ["planning", "execution", "verification", "review", "integration"] },
          "readPathPrefixes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "writePathPrefixes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "capabilities": {
            "type": "array",
            "items": { "enum": ["phase-output", "backend-write", "frontend-write", "backend-test-write"] },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
