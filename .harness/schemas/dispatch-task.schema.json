{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/dispatch-task.schema.json",
  "title": "FrontierScan Harness Dispatch Task",
  "type": "object",
  "required": [
    "schemaVersion",
    "dispatchId",
    "storyId",
    "phase",
    "ownerAgent",
    "purpose",
    "preparedRevision",
    "preparedAt",
    "expectedOutputs",
    "allowedAdapters",
    "next"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "dispatchId": { "type": "string", "format": "uuid" },
    "storyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "phase": { "type": "string", "minLength": 1 },
    "ownerAgent": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "preparedRevision": { "type": "integer", "minimum": 1 },
    "preparedAt": { "type": "string", "format": "date-time" },
    "expectedOutputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowedAdapters": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "next": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
