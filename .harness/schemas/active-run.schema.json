{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/active-run.schema.json",
  "title": "FrontierScan Harness Active Run Pointer",
  "type": "object",
  "required": ["schemaVersion", "runId", "stateFile", "status", "revision", "updatedAt"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "stateFile": { "type": "string", "pattern": "^\\.harness/states/e2e-[A-Za-z0-9][A-Za-z0-9._-]{0,63}\\.json$" },
    "status": { "type": "string", "enum": ["active", "blocked", "completed"] },
    "revision": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
