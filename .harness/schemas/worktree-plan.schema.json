{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/worktree-plan.schema.json",
  "title": "FrontierScan Harness Worktree Plan",
  "type": "object",
  "required": ["schemaVersion", "storyId", "runId", "taskId", "title", "ownerAgent", "wave", "taskDagFile", "taskDagSha256", "baseRef", "baseCommit", "branch", "worktreePath", "predictedFiles", "plannedAt"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "storyId": { "type": "string" },
    "runId": { "type": "string" },
    "taskId": { "type": "string" },
    "title": { "type": "string" },
    "ownerAgent": { "type": "string" },
    "wave": { "type": "integer", "minimum": 1 },
    "taskDagFile": { "type": "string" },
    "taskDagSha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "baseRef": { "type": "string" },
    "baseCommit": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" },
    "branch": { "type": "string" },
    "worktreePath": { "type": "string" },
    "predictedFiles": { "type": "array", "items": { "type": "string" } },
    "plannedAt": { "type": "string" }
  },
  "additionalProperties": false
}
