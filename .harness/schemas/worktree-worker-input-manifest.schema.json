{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/worktree-worker-input-manifest.schema.json",
  "title": "FrontierScan Harness Worktree Worker Input Manifest",
  "type": "object",
  "required": ["schemaVersion", "storyId", "runId", "taskId", "dispatchId", "baseCommit", "worktreePath", "inputs", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "storyId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "dispatchId": { "type": "string", "format": "uuid" },
    "baseCommit": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" },
    "worktreePath": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "sourcePath", "targetPath", "sha256", "bytes"],
        "properties": {
          "source": { "enum": ["main-run", "worktree-base"] },
          "sourcePath": { "type": "string", "minLength": 1 },
          "targetPath": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0, "maximum": 2097152 }
        },
        "additionalProperties": false
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
