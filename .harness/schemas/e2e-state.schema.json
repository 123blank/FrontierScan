{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontierscan.local/harness/e2e-state.schema.json",
  "title": "FrontierScan E2E Harness State",
  "type": "object",
  "required": [
    "schemaVersion",
    "storyId",
    "phase",
    "runtime",
    "requirement",
    "knowledge",
    "tasks",
    "dag",
    "worktrees",
    "tests",
    "review",
    "verification",
    "delivery",
    "logs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "storyId": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": [
        "requirement",
        "technical-design",
        "task-dag",
        "implementation",
        "unit-test",
        "code-review",
        "build-publish",
        "interface-verification",
        "git-delivery",
        "done",
        "blocked"
      ]
    },
    "runtime": {
      "type": "object",
      "required": [
        "runId",
        "workflow",
        "status",
        "revision",
        "previousPhase",
        "blocked",
        "records",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "runId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
        "workflow": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["template", "active", "blocked", "completed"] },
        "revision": { "type": "integer", "minimum": 0 },
        "previousPhase": { "type": ["string", "null"] },
        "blocked": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["previousPhase", "reason", "owner", "suggestedAction", "blockedAt", "resumedAt"],
              "properties": {
                "previousPhase": { "type": "string" },
                "reason": { "type": "string" },
                "owner": { "type": "string" },
                "suggestedAction": { "type": "string" },
                "blockedAt": { "type": "string" },
                "resumedAt": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          ]
        },
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "phase", "status", "path", "message", "actor", "createdAt"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["output", "test", "review", "approval", "note"] },
              "phase": { "type": "string" },
              "status": { "type": "string" },
              "path": { "type": ["string", "null"] },
              "message": { "type": "string" },
              "actor": { "type": "string" },
              "createdAt": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            },
            "additionalProperties": true
          }
        },
        "createdAt": { "type": ["string", "null"] },
        "updatedAt": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "requirement": {
      "type": "object",
      "required": ["summary", "openQuestions", "acceptanceCriteria"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "openQuestions": {
          "type": "array"
        },
        "acceptanceCriteria": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "required": ["loadedFiles", "staleFiles", "missingAreas"],
      "properties": {
        "loadedFiles": {
          "type": "array"
        },
        "staleFiles": {
          "type": "array"
        },
        "missingAreas": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "tasks": {
      "type": "array"
    },
    "dag": {
      "type": "object",
      "required": ["nodes", "edges", "waves"],
      "properties": {
        "nodes": {
          "type": "array"
        },
        "edges": {
          "type": "array"
        },
        "waves": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "worktrees": {
      "type": "array"
    },
    "tests": {
      "type": "object",
      "required": ["commands", "results"],
      "properties": {
        "commands": {
          "type": "array"
        },
        "results": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": ["findings", "status"],
      "properties": {
        "findings": {
          "type": "array"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": ["cases", "results"],
      "properties": {
        "cases": {
          "type": "array"
        },
        "results": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "delivery": {
      "type": "object",
      "required": ["ownedFiles", "commit", "pr"],
      "properties": {
        "ownedFiles": {
          "type": "array"
        },
        "commit": {
          "type": ["string", "null"]
        },
        "pr": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "logs": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
